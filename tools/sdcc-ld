#!/bin/bash
NEWARGS=()
TMPDIR_USED=$(mktemp -d)

for arg in "$@"; do
    if [[ "$arg" == *.o ]]; then
        newarg="${arg%.o}.rel"
        cp -- "$arg" "$newarg" 2>/dev/null || true
        NEWARGS+=("$newarg")
    elif [[ "$arg" == *.a ]]; then
        pushd "$TMPDIR_USED" > /dev/null
        ar -x "$arg"
        popd > /dev/null
        for obj in "$TMPDIR_USED"/*.o; do
            [[ -f "$obj" ]] || continue
            rel="${obj%.o}.rel"
            cp "$obj" "$rel"
            NEWARGS+=("$rel")
        done
    else
        NEWARGS+=("$arg")
    fi
done

exec /usr/bin/sdcc "${NEWARGS[@]}"
